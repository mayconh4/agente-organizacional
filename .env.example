# =====================================================================
# SalesOps AI — configuração
# Copie este arquivo para `.env` e preencha o que for usar.
# Qualquer canal sem credenciais cai automaticamente em dados de exemplo.
# =====================================================================

# ---- Geral -----------------------------------------------------------
SALESOPS_CLIENT="Loja XPTO"
# Canais a analisar (separados por vírgula): shopee, mercado_livre, amazon
SALESOPS_CHANNELS="shopee,mercado_livre,amazon"

# ---- Cérebro (Claude) ------------------------------------------------
# Sem esta chave o agente ainda roda, gerando um relatório por regras.
ANTHROPIC_API_KEY=""
# Modelo usado para diagnóstico/decisão (padrão: claude-opus-4-8)
SALESOPS_MODEL="claude-opus-4-8"

# Limiar de queda (%) que dispara um alerta de anomalia (padrão: 20)
SALESOPS_DROP_THRESHOLD="20"

# ---- Mercado Livre (https://developers.mercadolivre.com.br) ----------
# Access token OAuth2. O seller_id é descoberto automaticamente se vazio.
ML_ACCESS_TOKEN=""
ML_SELLER_ID=""

# ---- Shopee (https://open.shopee.com) --------------------------------
SHOPEE_PARTNER_ID=""
SHOPEE_PARTNER_KEY=""
SHOPEE_SHOP_ID=""
SHOPEE_ACCESS_TOKEN=""
# Região da API: BR usa partner.shopeemobile.com (padrão)
SHOPEE_HOST="https://partner.shopeemobile.com"

# ---- Amazon SP-API (https://sellercentral.amazon.com.br) -------------
# Login with Amazon (LWA): troca o refresh token por um access token.
AMAZON_LWA_CLIENT_ID=""
AMAZON_LWA_CLIENT_SECRET=""
AMAZON_REFRESH_TOKEN=""
# Endpoint regional do SP-API (Brasil/EUA usam a região NA)
AMAZON_SPAPI_ENDPOINT="https://sellingpartnerapi-na.amazon.com"
AMAZON_MARKETPLACE_ID="A2Q3Y263D00KWC"
